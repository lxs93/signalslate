generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at")
  exitTickets  ExitTicket[]
  sessions     Session[]
  accounts     Account[]

  @@map("users")
}

// ─── next-auth adapter tables ────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Exit Tickets ─────────────────────────────────────────────────────────────

model ExitTicket {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  title       String
  subject     String
  lessonTopic String       @map("lesson_topic")
  isOpen      Boolean      @default(true) @map("is_open")
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User         @relation(fields: [userId], references: [id])
  questions   Question[]
  submissions Submission[]
  analyses    Analysis[]

  @@map("exit_tickets")
}

// ─── Questions ───────────────────────────────────────────────────────────────

enum QuestionType {
  SHORT_ANSWER
  MULTIPLE_CHOICE
}

model Question {
  id           String           @id @default(cuid())
  exitTicketId String           @map("exit_ticket_id")
  prompt       String
  questionType QuestionType     @map("question_type")
  orderIndex   Int              @map("order_index")
  exitTicket   ExitTicket       @relation(fields: [exitTicketId], references: [id], onDelete: Cascade)
  options      QuestionOption[]
  responses    Response[]

  @@map("questions")
}

model QuestionOption {
  id         String    @id @default(cuid())
  questionId String    @map("question_id")
  optionText String    @map("option_text")
  orderIndex Int       @map("order_index")
  isCorrect  Boolean?  @map("is_correct")
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses  Response[]

  @@map("question_options")
}

// ─── Submissions & Responses ──────────────────────────────────────────────────

model Submission {
  id           String     @id @default(cuid())
  exitTicketId String     @map("exit_ticket_id")
  studentName  String     @map("student_name")
  submittedAt  DateTime   @default(now()) @map("submitted_at")
  exitTicket   ExitTicket @relation(fields: [exitTicketId], references: [id], onDelete: Cascade)
  responses    Response[]

  @@map("submissions")
}

model Response {
  id               String          @id @default(cuid())
  submissionId     String          @map("submission_id")
  questionId       String          @map("question_id")
  answerText       String?         @map("answer_text") @db.Text
  selectedOptionId String?         @map("selected_option_id")
  submission       Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question         Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  @@map("responses")
}

// ─── Analysis ────────────────────────────────────────────────────────────────

model Analysis {
  id                 String          @id @default(cuid())
  exitTicketId       String          @map("exit_ticket_id")
  overallSummary     String          @map("overall_summary") @db.Text
  strengthsText      String          @map("strengths_text") @db.Text
  misconceptionsText String          @map("misconceptions_text") @db.Text
  reteachSuggestion  String          @map("reteach_suggestion") @db.Text
  followupQuestion   String          @map("followup_question") @db.Text
  rawJson            Json            @map("raw_json")
  createdAt          DateTime        @default(now()) @map("created_at")
  exitTicket         ExitTicket      @relation(fields: [exitTicketId], references: [id], onDelete: Cascade)
  themes             AnalysisTheme[]
  followUpFlags      FollowUpFlag[]

  @@map("analyses")
}

enum ThemeType {
  MISCONCEPTION
  STRENGTH
  GENERAL
}

model AnalysisTheme {
  id         String    @id @default(cuid())
  analysisId String    @map("analysis_id")
  themeName  String    @map("theme_name")
  themeType  ThemeType @map("theme_type")
  analysis   Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("analysis_themes")
}

model FollowUpFlag {
  id          String   @id @default(cuid())
  analysisId  String   @map("analysis_id")
  studentName String   @map("student_name")
  reason      String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("follow_up_flags")
}
